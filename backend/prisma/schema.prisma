// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. UTILIZADORES E MUNDOS
// ==========================================

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  avatarUrl     String?
  worlds        World[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model World {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?    @db.Text
  genre       String?    // ex: "Fantasia Épica", "Sci-Fi"
  isPublic    Boolean    @default(false)
  
  // Relações
  races       Race[]
  professions Profession[]
  kingdoms    Kingdom[]
  locations   Location[]
  characters  Character[]
  timelines   Timeline[]
  events      Event[]
  concepts    Concept[]
  loreEntries LoreEntry[] 

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ==========================================
// 2. ELEMENTOS DO MUNDO
// ==========================================

model Race {
  id          String    @id @default(uuid())
  worldId     String
  world       World     @relation(fields: [worldId], references: [id], onDelete: Cascade)
  name        String
  description String?   @db.Text
  traits      Json?     // ex: ["Visão noturna", "+2 Força"]
  characters  Character[]
  createdAt   DateTime  @default(now())
}

model Profession {
  id              String     @id @default(uuid())
  worldId         String
  world           World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  name            String
  description     String?    @db.Text
  typicalSkills   Json?      // Habilidades típicas (ex: ["Forja", "Magia de Fogo"])
  requirements    String?    @db.Text // Requisitos para a profissão
  isTemplate      Boolean    @default(false)
  characters      Character[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Kingdom {
  id               String      @id @default(uuid())
  worldId          String
  world            World       @relation(fields: [worldId], references: [id], onDelete: Cascade)
  name             String
  description      String?     @db.Text
  governmentType   String?     
  
  // LIGAÇÃO 1: O Governante
  rulerCharacterId String?     @unique
  rulerCharacter   Character?  @relation("KingdomRuler", fields: [rulerCharacterId], references: [id])
  
  // LIGAÇÃO 2: Os Cidadãos
  characters       Character[] @relation("KingdomCitizens")
  
  createdAt        DateTime    @default(now())
}

model Location {
  id                String     @id @default(uuid())
  worldId           String
  world             World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  parentLocationId  String?    // Para hierarquia: Continente -> País -> Cidade
  parentLocation    Location?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  childLocations    Location[] @relation("LocationHierarchy")
  name              String
  type              String     // ex: "Continente", "Cidade", "Floresta"
  description       String?    @db.Text
  coordinates       String?    // ex: "N 45°, E 12°" ou texto livre
  events            Event[]
  createdAt         DateTime   @default(now())
}

// ==========================================
// 3. LINHA DO TEMPO E EVENTOS
// ==========================================

model Timeline {
  id          String    @id @default(uuid())
  worldId     String
  world       World     @relation(fields: [worldId], references: [id], onDelete: Cascade)
  name        String    // ex: "Terceira Era", "Calendário Imperial"
  description String?   @db.Text
  isPrimary   Boolean   @default(false) // A linha do tempo principal do mundo
  events      Event[]
  createdAt   DateTime  @default(now())
}

model Event {
  id            String     @id @default(uuid())
  worldId       String
  world         World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  timelineId    String?
  timeline      Timeline?  @relation(fields: [timelineId], references: [id])
  locationId    String?
  location      Location?  @relation(fields: [locationId], references: [id])
  
  name          String
  description   String?    @db.Text
  
  // Campos para ordenação cronológica real
  year          Int?       // ex: 305
  month         Int?       // ex: 7 (opcional)
  day           Int?       // ex: 12 (opcional)
  sortOrder     Int        @default(0) // Fallback para ordenar eventos sem data exata
  
  // Campo para exibição flexível (ex: "No ano da Grande Queda")
  displayDate   String?    
  
  characters    CharacterEvent[]
  createdAt     DateTime   @default(now())
}

// ==========================================
// 4. PERSONAGENS
// ==========================================

model Character {
  id            String     @id @default(uuid())
  worldId       String
  world         World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  
  raceId        String?
  race          Race?      @relation(fields: [raceId], references: [id])
  
  professionId  String?
  profession    Profession? @relation(fields: [professionId], references: [id])

  skills        Json?     // NOVO: Ex: ["Bola de Fogo Nível 3", "Furtividade"]
  
  // LIGAÇÃO 2: O Reino a que o personagem pertence (Cidadão)
  kingdomId     String?
  kingdom       Kingdom?   @relation("KingdomCitizens", fields: [kingdomId], references: [id])
  
  name          String
  alias         String?
  description   String?    @db.Text
  age           String?    
  alignment     String?    
  
  birthYear     Int?       
  deathYear     Int?       
  isAlive       Boolean    @default(true)

  events        CharacterEvent[]
  
  // LIGAÇÃO 1: O Reino que o personagem governa (Governante)
  ruledKingdom  Kingdom?   @relation("KingdomRuler") 
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Concept {
  id          String    @id @default(uuid())
  worldId     String
  world       World     @relation(fields: [worldId], references: [id], onDelete: Cascade)
  name        String    // Ex: "A Teia Mágica", "O Pacto de Sangue"
  description String    @db.Text
  createdAt   DateTime  @default(now())
}

// Adiciona isto ao teu schema.prisma (antes do CharacterEvent)

model LoreEntry {
  id          String    @id @default(uuid())
  worldId     String
  world       World     @relation(fields: [worldId], references: [id], onDelete: Cascade)
  
  category    String    // Ex: "DEITY", "SPELL", "ITEM", "LAW", "CUSTOM", "AFTERMATH"
  name        String
  description String    @db.Text // Texto rico para a lore profunda
  
  // A MÁGICA DA ORGANIZAÇÃO FLEXÍVEL
  customData  Json?     // Dados específicos (ex: {"dano": "2d6"} ou {"populacao_afetada": "30%"})
  tags        String[]  // Ex: ["Fogo", "Proibido", "Élfico"]
  relatedIds  String[]  // IDs de outros entries, personagens ou locais relacionados
  
  // RESOLVENDO A QUESTÃO DA ESCALA
  scale       String    @default("LOCAL") // "VILLAGE", "CITY", "REGION", "CONTINENT", "PLANETARY"
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}



// Tabela de junção para relação N:N entre Personagens e Eventos
model CharacterEvent {
  characterId   String
  character     Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  eventId       String
  event         Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  roleInEvent   String?    // ex: "Protagonista", "Vítima", "Observador"

  @@id([characterId, eventId])
}